#!/bin/bash
# 微信公众号文章抓取 CLI 封装

ARTICLE_URL="$1"
OUTPUT_DIR="${2:-/root/.openclaw/workspace/output/wechat-articles}"

if [ -z "$ARTICLE_URL" ]; then
    echo "用法: wechat-article <文章URL> [输出目录]"
    echo "示例: wechat-article 'https://mp.weixin.qq.com/s/xxxx' /root/.openclaw/workspace/output"
    exit 1
fi

cd /root/.openclaw/workspace/tools/wechat-article-for-ai
python3 main.py "$ARTICLE_URL" -o "$OUTPUT_DIR" -v
