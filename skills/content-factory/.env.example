# Content Factory Environment Configuration

# WeChat Official Account Credentials (Required for auto-publishing)
# Get these from: https://mp.weixin.qq.com/ → 设置与开发 → 基本配置
# Required for publishing articles to WeChat Official Account

WECHAT_APP_ID=your-wechat-app-id-here
WECHAT_APP_SECRET=your-wechat-app-secret-here

# WeChat API Proxy (Optional - solves dynamic IP whitelist problem)
# Deploy the SCF proxy from scripts/wechat_proxy_scf/ to Tencent Cloud,
# then set these values. When set, all WeChat API calls route through the
# proxy's fixed IP instead of your local dynamic IP.
# See scripts/wechat_proxy_scf/DEPLOY.md for setup instructions.
WECHAT_PROXY_URL=
WECHAT_PROXY_TOKEN=

# NotebookLM Authentication (Required for cover photos and infographics)
# Authenticate using: notebooklm login
# This will open a browser for Google OAuth authentication
# Authentication state is stored in ~/.notebooklm/storage_state.json
# No API key needed - uses browser-based authentication
